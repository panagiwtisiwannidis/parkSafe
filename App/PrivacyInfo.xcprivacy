<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!--
        Privacy Manifest — required for all App Store submissions since May 2024.
        Declares which privacy-sensitive APIs the app uses and why.
        https://developer.apple.com/documentation/bundleresources/privacy_manifest_files
    -->

    <!-- The app does NOT track users across apps/websites -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No data is collected or sent to any server -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- Required-reason APIs used by the app -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>

        <!--
            UserDefaults — used to persist the saved parking spot and
            onboarding state locally on-device only (PersistenceService).
            Reason CA92.1: "Access info from the same app that previously stored it."
        -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>

    </array>

</dict>
</plist>
